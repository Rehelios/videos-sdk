node_modules
dist
coverage
*.log
.DS_Store
.env
.env.*
.astro
.wrangler
.next
out
.source
next-env.d.ts

# This is a Bun workspace: bun.lock is the only lockfile.
# A stray lockfile makes Dependabot and CI treat the repo as npm/yarn/pnpm.
yarn.lock
package-lock.json
pnpm-lock.yaml

# Tegami drafts changelog entries and the publish lock inside a single release run.
# Committing them is what let a half-finished release wedge the next one.
.tegami/changes/*
!.tegami/changes/.gitkeep
