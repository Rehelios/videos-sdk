{
  "name": "videos-sdk-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter videos-sdk build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter videos-sdk test",
    "lint": "biome check packages scripts",
    "format": "biome format --write packages scripts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "tegami": "^1.2.6",
    "typescript": "^6.0.3"
  }
}
