{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/dist/**",
      "!**/node_modules/**",
      "!**/.next/**",
      "!**/.source/**",
      "!**/.astro/**",
      "!**/.wrangler/**",
      "!**/build/**",
      "!**/out/**",
      "!**/coverage/**",
      "!**/apps/docs/**",
      "!**/*.gen.ts",
      "!**/routeTree.gen.ts"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": { "noExplicitAny": "error" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  }
}
