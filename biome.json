{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "**/dist/**",
      "**/node_modules/**",
      "**/.next/**",
      "**/.source/**",
      "**/.astro/**",
      "**/.wrangler/**",
      "**/build/**",
      "**/out/**",
      "**/coverage/**",
      "apps/docs/**",
      "**/*.gen.ts",
      "**/routeTree.gen.ts"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "error" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  }
}
